data/

# Local env files — env vars go in Vercel dashboard
.env.local
.env*.local

# Local test scripts — invoked via npm run, not the web app
src/scripts/

# Build artifacts
.next/
dist/

# Dev metadata
.DS_Store
*.log
.vscode/
.idea/

# Memory dir if you ever add one
memory/
