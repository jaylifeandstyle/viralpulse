{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/poll",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/target-scan",
      "schedule": "0 * * * *"
    }
  ],
  "functions": {
    "app/api/cron/poll/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/target-scan/route.ts": {
      "maxDuration": 60
    },
    "app/api/force-poll/route.ts": {
      "maxDuration": 60
    },
    "app/api/galaxy03-trends/route.ts": {
      "maxDuration": 60
    },
    "app/api/post-to-x/route.ts": {
      "maxDuration": 30
    },
    "app/api/growth/scan/route.ts": {
      "maxDuration": 60
    },
    "app/api/growth/candidates/[id]/route.ts": {
      "maxDuration": 30
    }
  }
}
