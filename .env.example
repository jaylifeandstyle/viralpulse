# ─── Anthropic (REQUIRED) ────────────────────────────────────────────────
# VP_ANTHROPIC_KEY exists because Claude Desktop injects an empty
# ANTHROPIC_API_KEY into shells, which silently beats .env.local.
# Set BOTH locally; in Vercel just set VP_ANTHROPIC_KEY (no conflict).
VP_ANTHROPIC_KEY=sk-ant-api03-...
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── X / Twitter (OPTIONAL — only needed for Galaxy.01/02/03 + Search) ───
# Galaxy.04 (news-first) does NOT need this.
X_BEARER_TOKEN=AAAAAAAA...

# ─── X posting (REQUIRED for the dashboard's Post Now button) ─────────────
# Bearer token above can only READ; posting needs OAuth 1.0a User Context.
# Get these at developer.twitter.com → your project → Keys and tokens →
# "Access Token and Secret" → Generate. Your App's User authentication
# settings MUST be Read+Write (not Read only) or every post returns 403.
# After changing permissions, regenerate the access token + secret.
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ─── Galaxy.05 auto-post (OPTIONAL) ──────────────────────────────────────
# When true, npm run galaxy05 posts the top shouldAct draft to X each cycle.
# Max 5/day by default (override with VP_AUTO_POST_MAX_DAY).
VP_AUTO_POST=false

# ─── Telegram push notifications (OPTIONAL) ──────────────────────────────
# 1. Telegram → message @BotFather → /newbot → save the token below
# 2. Open a chat with your new bot, send it any message
# 3. Run:  npm run telegram:setup
#    The script validates the token, finds your chat_id, and sends a test
#    message. Avoids the 404-prone browser-URL flow.
# Leave blank to disable Telegram pushes — the integration silently no-ops.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Public base URL used by Telegram's "Post on X" button to route through
# /api/r/x — detects mobile UA and redirects to twitter:// (X native app).
# Leave unset to fall back to https://x.com/intent/post (works, but takes
# 2 taps on mobile).
#   Local dev (same wifi): http://<your-mac-LAN-IP>:3000
#   Vercel deployment:     https://<your-app>.vercel.app
VP_PUBLIC_BASE_URL=

# ─── Vercel cron (REQUIRED on Vercel) ────────────────────────────────────
# Vercel sets this automatically when you add a cron job. Locally, set any
# string and pass it as Authorization: Bearer <value> when testing /api/cron/poll.
CRON_SECRET=

# ─── Cron behavior on Vercel (OPTIONAL) ──────────────────────────────────
# Which galaxy the hourly cron runs. Default galaxy.04 (no X token needed).
# Set to galaxy.05 for hybrid (BBC + X Trends + optional auto-post).
GALAXY_CRON_MODE=galaxy.04

# ─── Storage backend (PRODUCTION) ────────────────────────────────────────
# The store auto-detects backend on first call:
#   • If UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN → @upstash/redis
#     (persistent, used on Vercel)
#   • Otherwise → file-based (data/opportunities.json, local dev only)
#
# On Vercel, go to Storage tab → connect an Upstash Redis integration to
# your project. Vercel auto-injects these env vars — you don't paste them
# manually. Make sure the URL value starts with https:// (REST endpoint),
# NOT redis:// (TCP endpoint) — @upstash/redis only speaks REST.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Legacy KV_REST_API_* names (from the deprecated @vercel/kv era) are also
# accepted by the dispatcher for backward compatibility. Don't set both.
# Optional override — force "kv" or "file" regardless of detection:
#   VP_STORE_BACKEND=kv   (use Upstash even if vars set locally)
#   VP_STORE_BACKEND=file (use file even on Vercel — not recommended)
VP_STORE_BACKEND=
